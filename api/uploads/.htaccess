# Files here are only ever served through resume.php (which validates
# the filename and streams it with the correct headers). Block all
# direct access and never execute anything in here as a script.
Options -Indexes -ExecCGI
AddHandler cgi-script .php .php3 .php4 .php5 .phtml .pl .py .cgi .asp .aspx .sh
RemoveHandler .php .php3 .php4 .php5 .phtml

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>
