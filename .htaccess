# Zeekers Technology Solutions — Root .htaccess
# Place this in your public_html (or domain root) on Hostinger

Options -Indexes
DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ── Redirect old /lab URL to the new /education URL ──────
    RewriteRule ^lab/?$ /education [R=301,L]
    RewriteRule ^lab\.html$ /education [R=301,L]

    # ── Serve existing files/dirs as-is ──────────────────────
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ── API requests pass through ────────────────────────────
    RewriteRule ^api/ - [L]

    # ── Clean URL: /education → education.html ───────────────
    RewriteRule ^education/?$ education.html [L]
</IfModule>

# ── Compression ──────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── Cache static assets ──────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css             "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg           "access plus 1 year"
    ExpiresByType image/png            "access plus 1 year"
    ExpiresByType image/webp           "access plus 1 year"
    ExpiresByType image/svg+xml        "access plus 1 month"
</IfModule>
